rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- FUNCIONES ---
    function estaAutenticado() {
      return request.auth != null;
    }

    function esAdmin() {
      return request.auth.token.email == 'admin@nelsystems.com' ||
             (exists(/databases/$(database)/documents/usuarios/$(request.auth.uid)) &&
              get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.rol in ['admin', 'superadmin']);
    }

    // --- REGLAS ---

    match /usuarios/{userId} {
      allow read: if estaAutenticado();
      allow create, delete: if esAdmin();
      allow update: if esAdmin() || request.auth.uid == userId;
    }

    match /citas/{citaId} {
      allow read, create, update: if estaAutenticado();
      allow delete: if esAdmin();
    }

    match /pacientes/{pacienteId} {
      allow read, write: if estaAutenticado();
    }

    match /expedientes/{pacienteId} {
      allow read, write: if estaAutenticado();

      match /sesiones/{sesionId} {
        allow read, write: if estaAutenticado();
      }
    }

    // Wildcard necesario para collectionGroup('sesiones') — usado en KPIs
    match /{path=**}/sesiones/{sesionId} {
      allow read: if estaAutenticado();
      allow write: if estaAutenticado();
    }

    match /servicios/{servicioId} {
      allow read: if true;
      allow write: if esAdmin();
    }

    match /solicitudes/{id} {
      allow create: if true;
      allow read, update, delete: if esAdmin();
    }
  }
}
