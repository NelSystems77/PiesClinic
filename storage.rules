rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function estaAutenticado() {
      return request.auth != null;
    }

    // Fotos clínicas de pacientes (sesiones)
    match /fotos/{allPaths=**} {
      allow read, write: if estaAutenticado();
    }

    // Firmas digitales de pacientes
    match /pacientes/{allPaths=**} {
      allow read, write: if estaAutenticado();
    }

    // Imágenes del catálogo de servicios — lectura pública, escritura solo autenticado
    match /servicios/{allPaths=**} {
      allow read: if true;
      allow write: if estaAutenticado();
    }
  }
}
